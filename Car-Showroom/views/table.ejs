<!DOCTYPE html>
<html lang="en">

<head>
    <title>Car Showroom Inventory</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <style>
        .card {
            border-radius: 15px;
            overflow: hidden;
            transition: transform 0.3s ease-in-out;
        }

        .card:hover {
            transform: scale(1.05);
        }

        .badge-green {
            position: absolute;
            top: 10px;
            left: 10px;
            background-color: #28a745;
            color: white;
            padding: 5px 10px;
            border-radius: 10px;
            font-size: 12px;
        }

        .details {
            display: flex;
            justify-content: space-around;
            font-size: 14px;
            color: gray;
        }

        .details i {
            margin-right: 5px;
        }
    </style>
</head>

<body>
    

    <div class="container my-4">
        <h1 class="text-center mb-5">Car Showroom Inventory</h1>
        
        <div class="row g-4">
            <%  record.map((e) => { 
                const { id, brand, model, price, color, image} = e; %>
                <div class="col-md-3">
                    <div class="card shadow-lg position-relative">
                        <span class="badge-green">Great Price</span>
                        <img src="<%= image %>" class="card-img-top" alt="Car Image" style="height: 200px; object-fit: cover;">
                        <div class="card-body bg-dark text-white rounded-bottom">
                            <h5 class="card-title"><%= brand %> - <%= model %></h5>
                            <p class="card-text"><strong>Price:</strong> ₹<%= price %></p>
                            <p class="card-text"><strong>Color:</strong> <%= color %></p>

                            <div class="d-flex justify-content-between mt-3">
                                <a href="/edit?id=<%= id %>" class="btn btn-warning">Edit</a>
                                <a href="/delete/<%= id %>" class="btn btn-danger">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <div class="text-center mt-4">
            <a href="/form" class="btn btn-primary">Add Car</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
