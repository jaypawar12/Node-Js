<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MovieMania</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        :root {
            --dark-bg: #121212;
            --glass-bg: rgba(255, 255, 255, 0.05);
            --text-light: #f5f5f5;
            --primary: #ff4c60;
        }

        body {
            background-color: var(--dark-bg);
            color: var(--text-light);
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar {
            backdrop-filter: blur(10px);
            background-color: rgba(0, 0, 0, 0.6);
            transition: all 0.3s ease;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.8rem;
            color: #fff !important;
        }

        .nav-link {
            color: #fff !important;
            font-weight: 500;
            margin-left: 1rem;
        }

        .banner {
            background: linear-gradient(to right, rgba(0, 0, 0, 0.8), rgba(18, 18, 18, 0.9)),
                url('https://images.unsplash.com/photo-1606112219348-204d7d8b94ee?fit=crop&w=1400&q=80') center/cover no-repeat;
            padding: 140px 0;
            text-align: center;
            color: white;
        }

        .banner h1 {
            font-size: 3.5rem;
            font-weight: 800;
        }

        .banner p {
            font-size: 1.2rem;
        }

        .btn-glow {
            background-color: var(--primary);
            border: none;
            color: white;
            padding: 12px 28px;
            font-weight: 600;
            border-radius: 30px;
            transition: all 0.3s ease-in-out;
        }

        .btn-glow:hover {
            box-shadow: 0 0 15px var(--primary);
            transform: scale(1.05);
        }

        .movie-card {
            background: var(--glass-bg);
            border: none;
            border-radius: 18px;
            overflow: hidden;
            backdrop-filter: blur(8px);
            transition: 0.3s ease-in-out;
        }

        .movie-card:hover {
            transform: scale(1.03);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
        }

        .card-img-top {
            height: 240px;
            object-fit: cover;
        }

        .card-body {
            padding: 1rem;
        }

        .card-title {
            color: #ffc107;
        }

        .rating {
            color: #f9d923;
        }

        footer {
            background-color: #1a1a1a;
            color: #aaa;
            padding: 30px 0;
        }

        .social-icons a {
            color: #ccc;
            font-size: 1.4rem;
            margin: 0 10px;
            transition: 0.3s;
        }

        .social-icons a:hover {
            color: var(--primary);
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="#">🎬 MovieMania</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto text-uppercase">
                    <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/form">Add Movie</a></li>
                    <li class="nav-item"><a class="nav-link" href="#features">Features</a></li>
                    <li class="nav-item"><a class="nav-link" href="#movieInventory">Collection</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Banner -->
    <section class="banner">
        <div class="container">
            <h1>Welcome to MovieMania</h1>
            <p class="mb-4">Your stylish personal movie library</p>
            <a href="/form" class="btn btn-glow">Add New Movie</a>
        </div>
    </section>

    <!-- Movie Collection -->
    <div class="container my-5" id="movieInventory">
        <h2 class="text-center mb-5 fw-bold text-warning">Movie Collection</h2>
        <div class="row g-4">
            <!-- Dynamic Cards from EJS -->
            <% record.forEach((e)=> { %>
                <div class="col-md-4 col-lg-3">
                    <div class="card movie-card h-100">
                        <img src="<%= e.movieImage %>" class="card-img-top" alt="Movie Image" />
                        <div class="card-body text-center d-flex flex-column">
                            <h5 class="card-title mb-2">
                                <%= e.movieName %>
                            </h5>
                            <p class="mb-1"><i class="bi bi-cash-coin me-1"></i> ₹<%= e.ticketPrice %>
                            </p>
                            <p class="mb-1"><i class="bi bi-film me-1"></i>
                                <%= e.genre %>
                            </p>
                            <p class="text-muted small mb-2 text-white">
                                <%= e.description %>
                            </p>
                            <div class="rating mb-2">
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star"></i>
                                <i class="bi bi-star"></i>
                            </div>
                            <div class="mt-auto d-flex justify-content-center gap-2">
                                <a href="/updateMovie/<%= e.id %>" class="btn btn-sm btn-warning">Edit</a>
                                <a href="/delete/delMovie?id=<%= e.id %>" class="btn btn-sm btn-danger">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>


    <!-- Features Section -->
    <section class="py-5" id="features">
        <div class="container text-center">
            <h2 class="mb-4 fw-bold text-warning">Why Use MovieMania?</h2>
            <div class="row text-light">
                <div class="col-md-4 mb-4">
                    <i class="bi bi-collection-play-fill display-4 text-primary mb-3"></i>
                    <h5 class="fw-semibold">Your Personal Movie Shelf</h5>
                    <p>Keep track of every movie you've watched, want to watch, or absolutely love — all in one stylish
                        place.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <i class="bi bi-pencil-square display-4 text-primary mb-3"></i>
                    <h5 class="fw-semibold">Full Control</h5>
                    <p>Add, update, or delete any movie from your collection with ease. You're always in control of your
                        library.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <i class="bi bi-star-fill display-4 text-primary mb-3"></i>
                    <h5 class="fw-semibold">Rate & Sort</h5>
                    <p>Rate your favorites and sort your collection by genre, price, or title to find the perfect film
                        every time.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <!-- <section class="py-5 bg-dark">
